{
  "name": "amwebexpert",
  "description": "André Masson — Professional CV / Resume",
  "private": true,
  "version": "1.8.0",
  "type": "module",
  "author": "André Masson",
  "repository": "https://github.com/amwebexpert/amwebexpert",
  "scripts": {
    "start": "yarn dev",
    "dev": "vite",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 rimraf dist && tsc -b && vite build",
    "deploy": "npm run build && rimraf docs && shx mv dist docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "npx tsc --noEmit --project tsconfig.app.json",
    "preview": "vite preview",
    "generate:version": "node scripts/generate-version.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "6.2.5",
    "@lichens-innovation/ts-common": "1.16.0",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.15",
    "@uidotdev/usehooks": "2.4.1",
    "antd": "6.4.3",
    "i18next": "26.3.1",
    "i18next-browser-languagedetector": "8.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.8",
    "react-icons": "5.6.0",
    "sonner": "2.0.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tanstack/router-plugin": "1.168.18",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "cross-env": "10.1.0",
    "eslint": "10.4.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "rimraf": "6.1.3",
    "shx": "0.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "8.0.16",
    "vite-tsconfig-paths": "6.1.1"
  }
}
