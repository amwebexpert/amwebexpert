{
  "name": "amwebexpert",
  "description": "André Masson — Professional CV / Resume",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "author": "André Masson",
  "repository": "https://github.com/amwebexpert/amwebexpert",
  "scripts": {
    "start": "yarn dev",
    "dev": "vite",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 rimraf dist && tsc -b && vite build",
    "deploy": "npm run build && rimraf docs && shx mv dist docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "npx tsc --noEmit --project tsconfig.app.json",
    "preview": "vite preview",
    "generate:version": "node scripts/generate-version.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "5.6.1",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-router": "1.168.26",
    "@uidotdev/usehooks": "2.4.1",
    "antd": "6.3.1",
    "i18next": "25.8.14",
    "i18next-browser-languagedetector": "8.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.6",
    "react-icons": "5.6.0",
    "sonner": "2.0.7",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "9.28.0",
    "@tanstack/router-plugin": "1.168.14",
    "@types/node": "22.15.21",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5",
    "@vitejs/plugin-react": "4.5.2",
    "cross-env": "7.0.3",
    "eslint": "9.28.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "16.2.0",
    "rimraf": "6.0.1",
    "shx": "0.3.4",
    "typescript": "5.8.3",
    "typescript-eslint": "8.34.0",
    "vite": "6.3.5",
    "vite-tsconfig-paths": "5.1.4"
  }
}
